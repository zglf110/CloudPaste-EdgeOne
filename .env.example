# CloudPaste EdgeOne 部署示例
# 将此文件作为参考。在 EdgeOne Pages 控制台中配置环境变量，不要把真实密钥提交到仓库。

# 平台
CLOUD_PLATFORM=edgeone

# MySQL（EdgeOne 推荐使用外部 MySQL）
MYSQL_HOST=your-mysql-host.com
MYSQL_PORT=3306
MYSQL_USER=cloudpaste_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=cloudpaste
MYSQL_SSL=true

# 加密/安全
# 强烈建议使用 32 字节或以上随机密钥，例如：openssl rand -base64 32
ENCRYPTION_SECRET=your-32-character-random-secret
SIGN_SECRET=
JWT_SECRET=
SESSION_SECRET=

# 任务/定时
TASK_WORKER_POOL_SIZE=10
# 注意：某些环境变量管理界面不允许值中包含空格、换行或制表符。若平台限制，请使用下划线或 Base64 编码存储并在程序中还原。
# 示例：将 cron 表达式替换空格为下划线，并在代码中解析回原始表达式，或在控制台直接填写不受限制的原始值。
SCHEDULED_TICK_CRON=*/1_*_*_*_*

# 对象存储（EdgeOne 推荐使用 R2；其他存储可选）
STORAGE_PROVIDER=r2   # r2 | b2 | local

# 如果使用 R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# 日志与调试
DEBUG_LOG=false
DEBUG_SQL=false
DEBUG_DB=false
LOG_LEVEL=warn

# 可选：CI 凭证（如需要此类迁移/操作时再添加）

# 管理员示例（仅本地快速启动用）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# 说明：
# 1) 在 EdgeOne Pages 控制台中创建项目后，请在“环境变量”处逐个添加以上变量和值。
# 2) 不要将真实密钥写入仓库中的文件。仅将示例文件用于参考。
# 3) 生成 ENCRYPTION_SECRET 示例：
#    openssl rand -base64 32
# 4) 本地测试可将此文件复制为 .env：
#    cp .env.edgeone.example .env
#    然后运行本地开发命令（参见 README_EDGEONE.md）。
